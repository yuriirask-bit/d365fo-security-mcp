# D365 F&O Security MCP Server — Environment Configuration
# Copy this file to .env and fill in your values.

# D365 F&O environment URL (no trailing slash)
D365FO_BASE_URL=https://your-environment.operations.dynamics.com

# Azure AD / Entra ID tenant
D365FO_TENANT_ID=your-tenant-id-here

# App Registration credentials (service principal)
D365FO_CLIENT_ID=your-client-id-here
D365FO_CLIENT_SECRET=your-client-secret-here

# Optional: Licence source provider (assess-only | file | graph | ppac)
# LICENCE_SOURCE=assess-only

# Optional: Path to licence file (when LICENCE_SOURCE=file)
# LICENCE_FILE_PATH=./licences.csv

# Optional: Currency code for cost calculations (ISO 4217)
# CURRENCY=GBP

# Optional: Path to SoD conflict ruleset JSON file
# Use examples/sod-rules-sample.json for testing; replace with your production ruleset
# See docs/sod-ruleset-format.md for the file format
# SOD_RULES_FILE=./examples/sod-rules-sample.json
